{
  "projectType": "sdk-library",
  "projectName": "sidekiq-unique-jobs",
  "projectDescription": "A Ruby gem that prevents duplicate Sidekiq jobs by using Redis locks to enforce uniqueness based on configurable job arguments and lifecycle strategies.",
  "theme": "luma",
  "primaryColor": "#41b1f8",
  "lightColor": "#042b93",
  "darkColor": "#cee4f4",
