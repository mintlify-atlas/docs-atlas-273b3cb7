  "keyFeatures": [
    "Multiple lock types covering the full job lifecycle (enqueue, execute, expiry)",
    "Configurable conflict strategies: log, raise, reject, replace, reschedule",
    "Custom lock arguments to control which job parameters determine uniqueness",
    "Reflection/observability hooks for lock lifecycle events",
    "Orphan lock reaper (Ruby and Lua implementations) for crash recovery",
    "ReliableFetch strategy with atomic LMOVE and lock-aware acknowledgment",
    "Sidekiq Web UI extension to browse, filter, and delete locks",
    "CLI tool (uniquejobs) for managing locks from the command line",
    "Thread-safe configuration with per-job overrides",
    "FIPS-compatible modern digest algorithm option"
  ],
  "publicApiSurface": [
    "SidekiqUniqueJobs::Middleware::Client",
    "SidekiqUniqueJobs::Middleware::Server",
    "SidekiqUniqueJobs.configure { |config| ... }",
    "SidekiqUniqueJobs.reflect { |on| ... }",
    "SidekiqUniqueJobs::Fetch::Reliable",
    "SidekiqUniqueJobs::Server.configure(config)",
    "sidekiq_options lock: :until_executed",
    "sidekiq_options on_conflict: :reject",
    "sidekiq_options lock_args_method: ->(args) { ... }",
    "sidekiq_options lock_ttl: 3600",
    "sidekiq_options lock_timeout: 0",
    "sidekiq_options unique_across_queues: true",
    "sidekiq_options unique_across_workers: true",
    "SidekiqUniqueJobs::Lock::UntilExecuting",
    "SidekiqUniqueJobs::Lock::UntilExecuted",
    "SidekiqUniqueJobs::Lock::UntilExpired",
    "SidekiqUniqueJobs::Lock::WhileExecuting",
    "SidekiqUniqueJobs::Lock::WhileExecutingReject",
    "SidekiqUniqueJobs::Lock::UntilAndWhileExecuting",
    "SidekiqUniqueJobs::OnConflict::Log",
    "SidekiqUniqueJobs::OnConflict::Raise",
    "SidekiqUniqueJobs::OnConflict::Reject",
    "SidekiqUniqueJobs::OnConflict::Replace",
    "SidekiqUniqueJobs::OnConflict::Reschedule",
    "SidekiqUniqueJobs::Config#add_lock(name, klass)",
    "SidekiqUniqueJobs::Config#add_strategy(name, klass)",
    "uniquejobs list PATTERN",
    "uniquejobs del PATTERN",
    "uniquejobs console"
  ]
}
